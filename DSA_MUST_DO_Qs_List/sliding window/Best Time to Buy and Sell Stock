class Solution {
public:
    int maxProfit(vector<int>& prices)
    {
        int maxProfit = 0;
        int n = prices.size();

        for(int i = 0; i < n; i++)          // Buy day
        {
            for(int j = i + 1; j < n; j++)  // Sell day
            {
                maxProfit = max(maxProfit,
                                prices[j] - prices[i]);
            }
        }

        return maxProfit;
    }
};
