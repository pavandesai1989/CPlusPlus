class Solution {
public:
    vector<vector<int>> threeSum(vector<int>& nums) 
    {
        set<vector<int>> res;
        int n=nums.size();

        for(int i=0;i<n;i++)
        {
           for(int j=i+1;j<n;j++)
           {
              for(int k=j+1;k<n;k++)
              {
                if(nums[i]+nums[j]+nums[k]==0)
                {
                    vector<int> temp = {nums[i],nums[j],nums[k]};
                    sort(temp.begin(),temp.end());
                    res.insert(temp);
                }
              }
           }
        }

        return vector<vector<int>>(res.begin(),res.end());        
    }
};

Notes:
Idea:
Try every possible triplet.

for(i)
    for(j)
        for(k)

If sum == 0:
    Store triplet.

To remove duplicates:
1. Sort triplet
2. Insert into set

Complexity:
Time  : O(N³)
Space : O(K)

K = Number of unique triplets

