Use i to track the last unique element
and j to scan the array. When a new
unique element is found, place it at
i+1 and move i forward.

Time  : O(N)
Space : O(1)

class Solution {
public:
    int removeDuplicates(vector<int>& nums) 
    {
        int n=nums.size();
        int i=0;

        for(int j=i+1;j<n;j++)
        {
            if(nums[j]!=nums[i])
            {
                nums[i+1] = nums[j];
                i++;
            }
        }
        return i+1;
    }
};
