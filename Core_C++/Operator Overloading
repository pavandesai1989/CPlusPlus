=========================================================
MOST ASKED OPERATOR #1 : '+' Operator
=========================================================

class Complex
{
private:
    int real;
    int imag;

public:
    Complex(int r=0, int i=0)
        : real(r), imag(i)
    {
    }

    Complex operator+(const Complex& rhs)
    {
        return Complex(
                real + rhs.real,
                imag + rhs.imag
               );
    }

    void print()
    {
        cout << real
             << "+"
             << imag
             << "i\n";
    }
};

int main()
{
    Complex c1(10,20);
    Complex c2(30,40);

    Complex c3 = c1 + c2;

    c3.print();
}

Output:

40+60i

=========================================================
Compiler Internally Converts:
=========================================================

c1 + c2;

into

c1.operator+(c2);

=========================================================
MOST ASKED OPERATOR #2 : '<<' Operator
(Stream Insertion)
=========================================================

Needs Friend Function.

class Complex
{
    int real;
    int imag;

public:
    Complex(int r=0,int i=0)
        : real(r), imag(i)
    {
    }

    friend ostream&
    operator<<(ostream& out,
               const Complex& c);
};

ostream&
operator<<(ostream& out,
           const Complex& c)
{
    out << c.real
        << "+"
        << c.imag
        << "i";

    return out;
}

int main()
{
    Complex c(10,20);

    cout << c;
}

Output:

10+20i

=========================================================
WHY FRIEND?
=========================================================

Compiler converts:

cout << c;

into

operator<<(cout,c);

Left operand is:

ostream

NOT

Complex

Therefore member function won't work.

Use:

Friend/Non-member Function.

=========================================================
MOST ASKED OPERATOR #3 : '>>' Operator
(Stream Extraction)
=========================================================

class Complex
{
    int real;
    int imag;

public:
    friend istream&
    operator>>(istream& in,
               Complex& c);
};

istream&
operator>>(istream& in,
           Complex& c)
{
    in >> c.real >> c.imag;

    return in;
}

int main()
{
    Complex c;

    cin >> c;
}

=========================================================
MOST ASKED OPERATOR #4 : '=' Operator
(Copy Assignment)
=========================================================

class String
{
    char* ptr;

public:

    String& operator=
            (const String& rhs)
    {
        if(this != &rhs)
        {
            delete[] ptr;

            ptr = new char[
                  strlen(rhs.ptr)+1];

            strcpy(ptr,rhs.ptr);
        }

        return *this;
    }
};

=========================================================
WHY RETURN *this ?
=========================================================

Supports chaining.

s1 = s2 = s3;

=========================================================
MOST ASKED OPERATOR #5 : '[]' Operator
=========================================================

class Array
{
    int arr[5];

public:

    int& operator[](int index)
    {
        return arr[index];
    }
};

int main()
{
    Array a;

    a[0] = 100;

    cout << a[0];
}

Compiler converts:

a[0]

into

a.operator[](0);

=========================================================
MOST ASKED OPERATOR #6 : '()' Operator
(Function Call Operator)
=========================================================

class Add
{
public:
    int operator()(int a,
                   int b)
    {
        return a+b;
    }
};

int main()
{
    Add obj;

    cout << obj(10,20);
}

Output:

30

Objects behaving like functions are called:

Function Objects (Functors).

=========================================================
MOST ASKED OPERATOR #7 : '++'
(Pre Increment)
=========================================================

class Test
{
    int x;

public:
    Test(int a=0):x(a)
    {
    }

    Test& operator++()
    {
        ++x;
        return *this;
    }

    void print()
    {
        cout << x << endl;
    }
};

int main()
{
    Test t(10);

    ++t;

    t.print();
}

Output:

11

