5. IMPORTANT MEMBER FUNCTIONS
=========================================

get()
-----
Returns raw pointer (does NOT release ownership)

release()
---------
Releases ownership and returns raw pointer
(manual delete required)

reset()
------
Deletes current object and optionally assigns new one

swap()
-----
Swaps two unique_ptr objects

operator* / operator->
----------------------
Dereference like raw pointer

operator bool
-------------
Checks if pointer is valid (not null)

#include <iostream>
#include <memory>

using namespace std;

class Test
{
public:
    Test()
    {
        cout << "Constructor\n";
    }

    ~Test()
    {
        cout << "Destructor\n";
    }

    void display()
    {
        cout << "display()\n";
    }
};

int main()
{
    // 1. make_unique
    unique_ptr<Test> p1 = make_unique<Test>();

    // 2. operator->
    p1->display();

    // 3. get()
    cout << "Raw pointer: " << p1.get() << endl;

    // 4. move()
    unique_ptr<Test> p2 = move(p1);

    if (p1 == nullptr)
        cout << "p1 is null after move\n";

    // 5. reset()
    p2.reset(new Test());

    // 6. release()
    Test* rawPtr = p2.release();

    if (p2 == nullptr)
        cout << "p2 is null after release\n";

    delete rawPtr;  // Must delete manually

    // 7. bool check
    if (!p2)
        cout << "p2 is empty\n";

    return 0;
}

