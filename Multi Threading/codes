=========================================================
9. CONDITION VARIABLE (PRODUCER–CONSUMER)
=========================================================

#include <iostream>
#include <thread>
#include <queue>
#include <mutex>
#include <condition_variable>
using namespace std;

queue<int> q;
mutex m;
condition_variable cv;

void producer()
{
    for(int i = 1; i <= 5; i++)
    {
        unique_lock<mutex> lock(m);
        q.push(i);
        cout << "Produced: " << i << endl;
        cv.notify_one();
    }
}

void consumer()
{
    for(int i = 1; i <= 5; i++)
    {
        unique_lock<mutex> lock(m);

        cv.wait(lock, [] { return !q.empty(); });

        int val = q.front();
        q.pop();

        cout << "Consumed: " << val << endl;
    }
}

int main()
{
    thread t1(producer);
    thread t2(consumer);

    t1.join();
    t2.join();
}

