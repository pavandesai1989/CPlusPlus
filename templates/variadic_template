=========================================================
Variadic Template - Recursive Example ⭐⭐⭐⭐⭐
=========================================================

Code
-----

#include <iostream>
using namespace std;

void log()
{
    cout << "Base Function\n";
}

template<typename T, typename... Args>
void log(T first, Args... args)
{
    cout << first << endl;

    log(args...);
}

int main()
{
    log(1, 2.3, 'A', "Pavan");
}

