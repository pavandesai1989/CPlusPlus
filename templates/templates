5. Non-Type Template Parameter ⭐⭐⭐⭐
=========================================================

#include <iostream>
using namespace std;

template<typename T, int SIZE>
class Array
{
private:
    T arr[SIZE];

public:
    void set(int index, T value)
    {
        arr[index] = value;
    }

    void display() const
    {
        for(int i = 0; i < SIZE; i++)
            cout << arr[i] << " ";

        cout << endl;
    }
};

int main()
{
    Array<int,5> a;

    a.set(0,10);
    a.set(1,20);
    a.set(2,30);
    a.set(3,40);
    a.set(4,50);

    a.display();

    return 0;
}



