Copy Constructor:
Creates a new object from an existing object.

Copy Assignment Operator:
Copies data into an already existing object.

Copy Constructor is called during initialization.
Copy Assignment Operator is called during assignment.


=========================================================
COPY CONSTRUCTOR & COPY ASSIGNMENT OPERATOR
COMPLETE INTERVIEW EXAMPLE
=========================================================

#include <iostream>
using namespace std;

class Test
{
private:
    int* ptr;

public:

    // Constructor
    Test(int val)
    {
        ptr = new int(val);
        cout << "Constructor\n";
    }

    // Copy Constructor (Deep Copy)
    Test(const Test& other)
    {
        cout << "Copy Constructor\n";
        ptr = new int(*other.ptr);
    }

    // Copy Assignment Operator (Deep Copy)
    Test& operator=(const Test& other)
    {
        cout << "Copy Assignment Operator\n";

        if(this != &other)
        {
            delete ptr;
            ptr = new int(*other.ptr);
        }

        return *this;
    }

    void display()
    {
        cout << *ptr << endl;
    }

    ~Test()
    {
        delete ptr;
        cout << "Destructor\n";
    }
};

int main()
{
    Test t1(10);

    // Copy Constructor
    Test t2 = t1;

    // Copy Assignment Operator
    Test t3(20);
    t3 = t1;

    t1.display();
    t2.display();
    t3.display();
}

