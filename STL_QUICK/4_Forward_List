#include <iostream>
#include <forward_list>
using namespace std;

int main() {

    forward_list<int> fl;

    // -------------------------
    // push_front()
    // -------------------------
    fl.push_front(30);
    fl.push_front(20);
    fl.push_front(10);

    cout << "After push_front: ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // front()
    // -------------------------
    cout << "Front element: " << fl.front() << "\n";

    // -------------------------
    // insert_after()
    // -------------------------
    auto it = fl.begin();   // points to 10
    fl.insert_after(it, 15);

    cout << "After insert_after(10, 15): ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // erase_after()
    // -------------------------
    fl.erase_after(it); // removes 15

    cout << "After erase_after: ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // pop_front()
    // -------------------------
    fl.pop_front();

    cout << "After pop_front: ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // push more elements
    // -------------------------
    fl.push_front(5);
    fl.push_front(10);
    fl.push_front(20);

    cout << "Before remove/sort: ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // remove() - remove all occurrences
    // -------------------------
    fl.remove(10);

    cout << "After remove(10): ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // sort()
    // -------------------------
    fl.sort();

    cout << "After sort: ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // unique()
    // -------------------------
    fl.push_front(30);
    fl.push_front(30);
    fl.sort();
    fl.unique();

    cout << "After sort + unique: ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // reverse()
    // -------------------------
    fl.reverse();

    cout << "After reverse: ";
    for (auto x : fl) cout << x << " ";
    cout << "\n";

    // -------------------------
    // empty()
    // -------------------------
    cout << "Is empty? " << (fl.empty() ? "Yes" : "No") << "\n";

    // -------------------------
    // clear()
    // -------------------------
    fl.clear();

    cout << "After clear, empty? " << (fl.empty() ? "Yes" : "No") << "\n";

    return 0;
}
