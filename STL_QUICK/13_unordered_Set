-----------------------------------------
15. CODE EXAMPLE (MOST USED)
----------------------------------
#include <iostream>
#include <unordered_set>
using namespace std;

int main() {

    unordered_set<int> s;

    // insert
    s.insert(10);
    s.insert(20);
    s.insert(30);
    s.insert(10); // duplicate ignored

    // find
    if(s.find(20) != s.end())
        cout << "20 found" << endl;

    // count
    cout << s.count(10) << endl;

    // iterate
    for(auto it : s)
        cout << it << " ";

    cout << endl;

    // erase
    s.erase(20);

    cout << "Size: " << s.size() << endl;

    return 0;
}

-----------------------------------------
16. QUICK REVISION
------------------
- unordered_set = hash table
- stores unique elements
- NOT sorted
- O(1) average operations
- best for fast lookup + uniqueness
- duplicates automatically removed

-----------------------------------------
17. ONE-LINE INTERVIEW ANSWER
-----------------------------
unordered_set is a hash table-based container that stores unique elements with average O(1) insertion, 
deletion, and search, without maintaining any order.
