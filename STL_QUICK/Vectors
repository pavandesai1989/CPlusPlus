std::vector – INTERVIEW MASTER NOTES + CODE
=========================================

#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main() {

    // -------------------------------------
    // 1. INITIALIZATION
    // -------------------------------------

    vector<int> v1 = {1, 2, 3};            // initializer list

    vector<int> v2(5, 10);                 // size = 5, all values = 10

    int arr[] = {4, 5, 6};
    vector<int> v3(arr, arr + 3);          // from array

    vector<int> v4(v1.begin(), v1.end());  // from another vector


    // -------------------------------------
    // 2. BASIC OPERATIONS
    // -------------------------------------

    v1.push_back(100);     // add element
    v1.pop_back();         // remove last element

    cout << v1.size() << endl;      // number of elements
    cout << v1.capacity() << endl;  // allocated memory

    cout << v1.empty() << endl;     // check empty


    // -------------------------------------
    // 3. ACCESS ELEMENTS
    // -------------------------------------

    cout << v1[0] << endl;      // no bounds check
    cout << v1.at(0) << endl;    // bounds check

    cout << v1.front() << endl;  // first element
    cout << v1.back() << endl;   // last element


    // -------------------------------------
    // 4. INSERT / ERASE (IMPORTANT)
    // -------------------------------------

    v1.insert(v1.begin(), 50);        // insert at beginning
    v1.erase(v1.begin());             // erase first element

    v1.insert(v1.begin() + 1, 99);    // insert middle
    v1.erase(v1.begin() + 1);        // erase middle


    // -------------------------------------
    // 5. CLEAR / SHRINK
    // -------------------------------------

    v1.clear();              // remove all elements
    v1.shrink_to_fit();      // reduce capacity (not guaranteed)


    // -------------------------------------
    // 6. RESERVE vs RESIZE
    // -------------------------------------

    v1.reserve(100);         // only capacity increases

    v1.resize(5);            // size = 5, new elements = 0
    v1.resize(10, 7);        // size = 10, new elements = 7


    // -------------------------------------
    // 7. ITERATORS
    // -------------------------------------

    for (auto it = v2.begin(); it != v2.end(); it++) {
        cout << *it << " ";
    }
    cout << endl;

    for (auto it = v2.rbegin(); it != v2.rend(); it++) {
        cout << *it << " ";
    }
    cout << endl;


    // -------------------------------------
    // 8. DATA POINTER (C API USE CASE)
    // -------------------------------------

    int* ptr = v2.data();
    cout << ptr[0] << endl;


    // -------------------------------------
    // 9. SWAP (O(1))
    // -------------------------------------

    vector<int> a = {1, 2, 3};
    vector<int> b = {9, 8, 7};

    a.swap(b);


    // -------------------------------------
    // 10. SORT (VERY COMMON)
    // -------------------------------------

    vector<int> s = {5, 2, 9, 1};
    sort(s.begin(), s.end());


    // -------------------------------------
    // 11. EMPLACE vs PUSH_BACK
    // -------------------------------------

    vector<pair<int, int>> vp;

    vp.push_back({1, 2});        // copy/move
    vp.emplace_back(3, 4);       // constructs in place (faster)


    // -------------------------------------
    // 12. COPY vs MOVE
    // -------------------------------------

    vector<int> c1 = {1, 2, 3};
    vector<int> c2 = c1;              // COPY (O(n))

    vector<int> m1 = {4, 5, 6};
    vector<int> m2 = move(m1);       // MOVE (O(1))


    // -------------------------------------
    // 13. LOOPING
    // -------------------------------------

    for (int x : v2) {
        cout << x << " ";
    }
    cout << endl;


    return 0;
}

=========================================
VECTOR KEY POINTS (REVISION)
=========================================

- Dynamic array (heap)
- Contiguous memory
- O(1) random access
- push_back amortized O(1)
- reallocation = capacity full → new memory (usually 2x)
- iterators invalid on reallocation
- emplace_back avoids extra copy
- move is faster than copy
