#include <iostream>
using namespace std;

template<typename T>
class MyVector
{
private:
    T* arr;
    size_t sz;
    size_t cap;

    void reallocate(size_t newCap)
    {
        T* newArr = new T[newCap];

        for (size_t i = 0; i < sz; i++)
        {
            newArr[i] = arr[i];
        }

        delete[] arr;
        arr = newArr;
        cap = newCap;
    }

public:
    // Constructor
    MyVector()
    {
        sz = 0;
        cap = 1;
        arr = new T[cap];
    }

    // Destructor
    ~MyVector()
    {
        delete[] arr;
    }

    // Size
    size_t size() const
    {
        return sz;
    }

    // Capacity
    size_t capacity() const
    {
        return cap;
    }

    // Push Back
    void push_back(const T& value)
    {
        if (sz == cap)
        {
            reallocate(cap * 2);
        }

        arr[sz++] = value;
    }

    // Pop Back
    void pop_back()
    {
        if (sz > 0)
        {
            sz--;
        }
    }

    // Operator []
    T& operator[](size_t index)
    {
        return arr[index];
    }

    const T& operator[](size_t index) const
    {
        return arr[index];
    }

    // Get first element
    T& front()
    {
        return arr[0];
    }

    // Get last element
    T& back()
    {
        return arr[sz - 1];
    }

    // Clear
    void clear()
    {
        sz = 0;
    }

    // Empty
    bool empty() const
    {
        return sz == 0;
    }
};
