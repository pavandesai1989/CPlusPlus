13. CODE (MOST USED OPERATIONS)
----------------------------------
#include <iostream>
#include <map>
using namespace std;

int main() {

    map<int, string> m;

    // insert
    m[1] = "Apple";
    m[2] = "Banana";
    m[3] = "Mango";

    m.insert({4, "Grapes"});

    // access
    cout << m[2] << endl;

    // find
    if(m.find(3) != m.end())
        cout << "Found 3" << endl;

    // iteration
    for(auto it : m)
        cout << it.first << " -> " << it.second << endl;

    // erase
    m.erase(2);

    // size
    cout << m.size() << endl;

    // count
    cout << m.count(1) << endl;

    return 0;
}

