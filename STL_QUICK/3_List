-----------------------------------------

11. Special Functions
---------------------

remove(x):
- Removes all occurrences of x

sort():
- Member function of list (not std::sort)

reverse():
- Reverses list

unique():
- Removes consecutive duplicates

Example:
1 1 2 2 3 → 1 2 3

-----------------------------------------

12. Memory Overhead
-------------------
Each node stores:
- data
- prev pointer
- next pointer

👉 More memory than vector

-----------------------------------------

13. When to use list?
---------------------
Use list when:
✔ Frequent insert/delete in middle
✔ Iterator stability required

Avoid list when:
✗ Random access needed
✗ Cache performance important
✗ Mostly sequential access

-----------------------------------------

14. splice() (VERY IMPORTANT)
-----------------------------
- Moves elements between lists in O(1)
- No copying, only pointer changes

Example:
l1.splice(l1.end(), l2);

👉 l2 elements moved to l1

-----------------------------------------

15. list vs forward_list
------------------------

list:
- Doubly linked list
- Forward + backward traversal
- More memory

forward_list:
- Singly linked list
- Forward only
- Less memory

-----------------------------------------

16. One-line Interview Answer
----------------------------
std::list is a doubly linked list that provides O(1) insertion and deletion at known positions with stable iterators, 
but it does not support random access and has poor cache locality.

-----------------------------------------

17. KEY INTERVIEW SUMMARY
-------------------------
✔ Doubly linked list
✔ Non-contiguous memory
✔ O(1) insert/delete (if position known)
✔ No random access
✔ Iterator stable (except erased node)
✔ Higher memory overhead
✔ Slower than vector in most real cases due to cache misses

=========================================

#include <iostream>
#include <list>
using namespace std;

int main() {

    list<int> l;

    // -------------------------
    // push_back / push_front
    // -------------------------
    l.push_back(10);
    l.push_back(20);
    l.push_front(5);
    l.push_front(1);

    cout << "After push_front/back: ";
    for (auto x : l) cout << x << " ";
    cout << "\n";

    // -------------------------
    // front / back
    // -------------------------
    cout << "Front: " << l.front() << "\n";
    cout << "Back: " << l.back() << "\n";

    // -------------------------
    // insert (at position)
    // -------------------------
    auto it = l.begin();
    advance(it, 2);   // move iterator to position 2
    l.insert(it, 99);

    cout << "After insert: ";
    for (auto x : l) cout << x << " ";
    cout << "\n";

    // -------------------------
    // erase
    // -------------------------
    it = l.begin();
    advance(it, 1);
    l.erase(it);

    cout << "After erase: ";
    for (auto x : l) cout << x << " ";
    cout << "\n";

    // -------------------------
    // pop_front / pop_back
    // -------------------------
    l.pop_front();
    l.pop_back();

    cout << "After pop_front/back: ";
    for (auto x : l) cout << x << " ";
    cout << "\n";

    // -------------------------
    // size / empty
    // -------------------------
    cout << "Size: " << l.size() << "\n";
    cout << "Empty? " << (l.empty() ? "Yes" : "No") << "\n";

    // -------------------------
    // push more elements
    // -------------------------
    l.push_back(10);
    l.push_back(10);
    l.push_back(30);
    l.push_back(20);

    cout << "Before remove/unique: ";
    for (auto x : l) cout << x << " ";
    cout << "\n";

    // -------------------------
    // remove (remove all occurrences)
    // -------------------------
    l.remove(10);

    cout << "After remove(10): ";
    for (auto x : l) cout << x << " ";
    cout << "\n";

    // -------------------------
    // unique (remove consecutive duplicates)
    // -------------------------
    l.sort();   // important: unique works on consecutive duplicates
    l.unique();

    cout << "After sort + unique: ";
    for (auto x : l) cout << x << " ";
    cout << "\n";

    // -------------------------
    // reverse
    // -------------------------
    l.reverse();

    cout << "After reverse: ";
    for (auto x : l) cout << x << " ";
    cout << "\n";

    // -------------------------
    // clear
    // -------------------------
    l.clear();

    cout << "After clear, size = " << l.size() << "\n";

    return 0;
}
