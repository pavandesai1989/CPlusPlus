17. CODE EXAMPLE (MOST USED)
----------------------------------
#include <iostream>
#include <map>
using namespace std;

int main() {

    multimap<int, string> m;

    m.insert({1, "A"});
    m.insert({1, "B"});
    m.insert({2, "C"});
    m.insert({2, "D"});

    // iterate all
    for(auto it : m)
        cout << it.first << " -> " << it.second << endl;

    cout << "Count of 1: " << m.count(1) << endl;

    // find
    auto it = m.find(2);
    cout << "Find 2: " << it->first << " " << it->second << endl;

    // equal_range
    auto range = m.equal_range(1);
    cout << "All values for key 1:" << endl;
    for(auto i = range.first; i != range.second; i++)
        cout << i->first << " " << i->second << endl;

    // erase one element
    m.erase(m.begin());

    return 0;
}

