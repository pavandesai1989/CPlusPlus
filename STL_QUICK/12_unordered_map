15. CODE EXAMPLE (MOST USED)
----------------------------------
#include <iostream>
#include <unordered_map>
using namespace std;

int main() {

    unordered_map<int, string> m;

    // insert
    m[1] = "Apple";
    m[2] = "Banana";
    m[3] = "Mango";

    m.insert({4, "Grapes"});

    // access
    cout << m[2] << endl;

    // find
    if(m.find(3) != m.end())
        cout << "Found 3" << endl;

    // count
    cout << m.count(1) << endl;

    // iterate
    for(auto it : m)
        cout << it.first << " -> " << it.second << endl;

    // erase
    m.erase(2);

    cout << "Size: " << m.size() << endl;

    return 0;
}

-----------------------------------------
16. QUICK REVISION
------------------
- unordered_map = hash table
- keys are unique
- NOT sorted
- O(1) average operations
- worst case O(n)
- best for frequency / lookup problems

-----------------------------------------
17. ONE-LINE INTERVIEW ANSWER
-----------------------------
unordered_map is a hash table-based associative container that stores key-value pairs with average O(1) insert, delete, and search operations, but does not maintain any order.
