ONE-LINE ANSWER
----------------
std::stack is a container adaptor that follows LIFO order and provides O(1) push, pop, and top operations using 
deque as the default underlying container.

#include <iostream>
#include <stack>
#include <vector>
#include <list>
using namespace std;

int main()
{
    // Default: uses deque internally
    stack<int> s1;

    // Uses vector internally
    stack<int, vector<int>> s2;

    // Uses list internally
    stack<int, list<int>> s3;

    s1.push(10);
    s2.push(20);
    s3.push(30);

    cout << s1.top() << endl; // 10
    cout << s2.top() << endl; // 20
    cout << s3.top() << endl; // 30

    return 0;
}

