12. One-line Interview Answer

A deque is a sequence container implemented using multiple fixed-size memory blocks with a map of pointers, 
allowing O(1) insertion/removal at both ends and O(1) random access, but it is not stored in contiguous memory.

-----------------------------------------

13. VERY IMPORTANT DIFFERENCE

vector:
- single block memory
- fast cache access

deque:
- multiple blocks
- fast front + back operations

=========================================

#include <iostream>
#include <deque>
#include <algorithm>
using namespace std;

int main() {

    // ================================
    // 1. INITIALIZATION
    // ================================
    deque<int> dq = {10, 20, 30};

    // ================================
    // 2. PUSH OPERATIONS (MOST IMPORTANT)
    // ================================
    dq.push_back(40);     // back insert
    dq.push_front(5);     // front insert

    // dq = 5 10 20 30 40

    // ================================
    // 3. POP OPERATIONS
    // ================================
    dq.pop_back();        // remove last
    dq.pop_front();       // remove first

    // dq = 10 20 30

    // ================================
    // 4. ACCESS ELEMENTS
    // ================================
    cout << "Front: " << dq.front() << endl;  // 10
    cout << "Back: " << dq.back() << endl;    // 30

    cout << "Index 1: " << dq[1] << endl;     // 20
    cout << "At(2): " << dq.at(2) << endl;    // 30

    // ================================
    // 5. SIZE / EMPTY
    // ================================
    cout << "Size: " << dq.size() << endl;
    cout << "Empty: " << dq.empty() << endl;

    // ================================
    // 6. INSERT / ERASE (IMPORTANT)
    // ================================
    dq.insert(dq.begin() + 1, 99);   // insert at middle
    // dq = 10 99 20 30

    dq.erase(dq.begin() + 2);        // erase index 2
    // dq = 10 99 30

    // ================================
    // 7. CLEAR
    // ================================
    deque<int> temp = dq;
    temp.clear();

    cout << "After clear size: " << temp.size() << endl;

    // ================================
    // 8. LOOPING (VERY COMMON)
    // ================================
    cout << "Deque elements: ";
    for (auto x : dq) {
        cout << x << " ";
    }
    cout << endl;

    // ================================
    // 9. ITERATORS
    // ================================
    cout << "Forward: ";
    for (auto it = dq.begin(); it != dq.end(); it++) {
        cout << *it << " ";
    }
    cout << endl;

    cout << "Reverse: ";
    for (auto it = dq.rbegin(); it != dq.rend(); it++) {
        cout << *it << " ";
    }
    cout << endl;

    // ================================
    // 10. SWAP (O(1))
    // ================================
    deque<int> d1 = {1, 2, 3};
    deque<int> d2 = {9, 8, 7};

    d1.swap(d2);

    cout << "After swap d1: ";
    for (auto x : d1) cout << x << " ";
    cout << endl;

    // ================================
    // 11. SORT (via algorithm)
    // ================================
    sort(dq.begin(), dq.end());

    cout << "Sorted dq: ";
    for (auto x : dq) cout << x << " ";
    cout << endl;

    return 0;
}
