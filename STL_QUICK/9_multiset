14. Sample Code (Most Used in Interviews)
-----------------------------------------

#include <iostream>
#include <set>
using namespace std;

int main() {

    multiset<int> ms;

    // insert elements
    ms.insert(10);
    ms.insert(20);
    ms.insert(10);
    ms.insert(30);
    ms.insert(10);

    cout << "Multiset elements: ";
    for(auto x : ms)
        cout << x << " ";
    cout << endl;

    // count occurrences
    cout << "Count of 10: " << ms.count(10) << endl;

    // erase ONE occurrence
    ms.erase(ms.find(10));

    cout << "After deleting one 10: ";
    for(auto x : ms)
        cout << x << " ";
    cout << endl;

    // erase ALL occurrences
    ms.erase(20);

    cout << "After deleting all 20: ";
    for(auto x : ms)
        cout << x << " ";
    cout << endl;

    return 0;
}

