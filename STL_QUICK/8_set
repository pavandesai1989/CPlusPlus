16. Sample Code (Most Used in Interviews)
-----------------------------------------

#include <iostream>
#include <set>
using namespace std;

int main() {

    set<int> s;

    // insert
    s.insert(10);
    s.insert(30);
    s.insert(20);
    s.insert(10); // duplicate ignored

    cout << "Set elements: ";
    for(auto x : s)
        cout << x << " ";
    cout << endl;

    // find
    if(s.find(20) != s.end())
        cout << "20 found" << endl;

    // erase
    s.erase(30);

    cout << "After erase: ";
    for(auto x : s)
        cout << x << " ";
    cout << endl;

    // lower_bound
    auto it = s.lower_bound(15);
    if(it != s.end())
        cout << "Lower bound of 15: " << *it << endl;

    return 0;
}

