12. Common Stack Program
-----------------------------------------

#include <iostream>
#include <stack>

using namespace std;

int main()
{
    stack<int> st;

    st.push(10);
    st.push(20);
    st.push(30);

    cout << "Top: "
         << st.top() << endl;

    st.pop();

    cout << "Top after pop: "
         << st.top() << endl;

    cout << "Size: "
         << st.size() << endl;

    cout << "Empty? "
         << (st.empty() ? "Yes" : "No")
         << endl;

    return 0;
}

Output:

Top: 30
Top after pop: 20
Size: 2
Empty? No

