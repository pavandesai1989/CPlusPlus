=========================================
COMMON PROGRAM
=========================================

#include <iostream>
#include <set>

using namespace std;

int main()
{
    set<int> s;

    s.insert(30);
    s.insert(10);
    s.insert(20);
    s.insert(10);

    cout << "Elements: ";

    for(auto x : s)
        cout << x << " ";

    cout << endl;

    if(s.find(20) != s.end())
        cout << "Found 20" << endl;

    s.erase(20);

    cout << "After erase: ";

    for(auto x : s)
        cout << x << " ";

    return 0;
}

Output:
10 20 30
Found 20
10 30

