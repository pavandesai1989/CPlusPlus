=========================================
SAMPLE PROGRAM
=========================================

#include <iostream>
#include <array>
#include <algorithm>

using namespace std;

int main()
{
    array<int,5> arr = {5,2,4,1,3};

    cout << "Size: "
         << arr.size()
         << endl;

    cout << "Front: "
         << arr.front()
         << endl;

    cout << "Back: "
         << arr.back()
         << endl;

    cout << "Element at index 2: "
         << arr.at(2)
         << endl;

    sort(arr.begin(), arr.end());

    cout << "After Sort: ";

    for(auto x : arr)
        cout << x << " ";

    cout << endl;

    arr.fill(100);

    cout << "After Fill: ";

    for(auto x : arr)
        cout << x << " ";

    cout << endl;

    return 0;
}

