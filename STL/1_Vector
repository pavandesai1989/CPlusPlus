12. shrink_to_fit()
-------------------
int main() 
{
    vector<int> v;
    v.reserve(100);
    cout<<"Size"<<v.size()<<endl;//0
    cout<<"capacity"<<v.capacity()<<endl;//100

    v.resize(10);
    cout<<"Size"<<v.size()<<endl;//10
    cout<<"capacity"<<v.capacity()<<endl;//100

    v.shrink_to_fit();
    cout<<"Size"<<v.size()<<endl;//10
    cout<<"capacity"<<v.capacity()<<endl;//10
}

Example:
v.shrink_to_fit(); It requests the vector to reduce its capacity to match its current size.

Requests removal of unused capacity.

