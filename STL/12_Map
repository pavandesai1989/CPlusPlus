=========================================
COMMONLY USED MAP FUNCTIONS PROGRAM
=========================================

#include <iostream>
#include <map>

using namespace std;

int main()
{
    map<int,string> m;

    m[1] = "John";
    m[2] = "David";

    m.insert({3,"Mike"});

    cout << m[1] << endl;

    auto it = m.find(2);

    if(it != m.end())
        cout << it->second << endl;

    cout << "Count: "
         << m.count(3)
         << endl;

    m.erase(2);

    for(auto &p : m)
        cout << p.first
             << " "
             << p.second
             << endl;

    return 0;
}

