Same key with multiple values.

=========================================
COMMONLY USED MULTIMAP FUNCTIONS PROGRAM
=========================================

#include <iostream>
#include <map>

using namespace std;

int main()
{
    multimap<int,string> mm;

    mm.insert({1,"John"});
    mm.insert({1,"David"});
    mm.insert({2,"Mike"});

    cout << "Count of key 1 = "
         << mm.count(1)
         << endl;

    auto range = mm.equal_range(1);

    cout << "Values for key 1:" << endl;

    for(auto it = range.first;
        it != range.second;
        ++it)
    {
        cout << it->second << endl;
    }

    mm.erase(2);

    cout << "\nAll Elements:\n";

    for(auto &p : mm)
    {
        cout << p.first
             << " "
             << p.second
             << endl;
    }

    return 0;
}

