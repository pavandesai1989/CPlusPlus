=========================================================
std::shared_ptr - MOST COMMONLY USED FUNCTIONS
(Interview Quick Revision)
=========================================================

#include <iostream>
#include <memory>
using namespace std;

=========================================================
1. make_shared()
=========================================================

auto p = make_shared<int>(10);

cout << *p << endl;

Output:
10

Purpose:
Creates object and control block in a single allocation.

---------------------------------------------------------

auto p1 = make_shared<int>(100);
auto p2 = make_shared<string>("Hello");

=========================================================
2. Copy Construction (Shared Ownership)
=========================================================

auto p1 = make_shared<int>(10);
auto p2 = p1;

cout << p1.use_count() << endl;

Output:
2

Purpose:
Shares ownership and increments reference count.

=========================================================
3. Copy Assignment
=========================================================

auto p1 = make_shared<int>(10);
shared_ptr<int> p2;

p2 = p1;

cout << p1.use_count() << endl;

Output:
2

=========================================================
4. Move Constructor
=========================================================

auto p1 = make_shared<int>(10);
shared_ptr<int> p2 = move(p1);

if (!p1)
    cout << "p1 is empty\n";

cout << *p2 << endl;

Output:
p1 is empty
10

Purpose:
Transfers ownership without increasing reference count.

=========================================================
5. Dereference Operator (*)
=========================================================

auto p = make_shared<int>(50);

cout << *p << endl;

Output:
50

=========================================================
6. Arrow Operator (->)
=========================================================

auto p = make_shared<string>("Hello");

cout << p->size() << endl;

Output:
5

=========================================================
7. get()
=========================================================

auto p = make_shared<int>(100);

int* raw = p.get();

cout << *raw << endl;

Output:
100

NOTE:
Never do:

delete raw;   // WRONG

shared_ptr will delete the memory.

=========================================================
8. use_count()
=========================================================

auto p1 = make_shared<int>(10);

cout << p1.use_count() << endl;

auto p2 = p1;

cout << p1.use_count() << endl;

Output:
1
2

Purpose:
Returns number of shared owners.

=========================================================
9. reset()
=========================================================

auto p = make_shared<int>(10);

p.reset();

if (!p)
    cout << "empty\n";

Output:
empty

---------------------------------------------------------

auto p = make_shared<int>(10);

p.reset(new int(50));

cout << *p << endl;

Output:
50

Purpose:
Releases current resource and optionally manages new resource.

=========================================================
10. swap()
=========================================================

auto p1 = make_shared<int>(10);
auto p2 = make_shared<int>(20);

p1.swap(p2);

cout << *p1 << " " << *p2;

Output:
20 10

Purpose:
Swaps ownership.

Complexity:
O(1)

=========================================================
11. operator bool()
=========================================================

auto p = make_shared<int>(10);

if (p)
    cout << "Valid Pointer\n";

p.reset();

if (!p)
    cout << "Null Pointer\n";

Output:
Valid Pointer
Null Pointer

=========================================================
12. unique() (Pre-C++20)
=========================================================

auto p1 = make_shared<int>(10);

cout << p1.unique() << endl;

auto p2 = p1;

cout << p1.unique() << endl;

Output:
1
0

Purpose:
Returns true if only one owner exists.

NOTE:
Removed in C++20.

=========================================================
13. Comparison with nullptr
=========================================================

shared_ptr<int> p;

if (p == nullptr)
    cout << "Null\n";

Output:
Null

=========================================================
14. Custom Deleter
=========================================================

auto deleter = [](int* p)
{
    cout << "Deleting\n";
    delete p;
};

shared_ptr<int> p(new int(10), deleter);

=========================================================
15. Aliasing Constructor (Senior Level)
=========================================================

auto p1 = make_shared<vector<int>>(5);

shared_ptr<int> p2(p1, &(*p1)[0]);

Purpose:
Shares ownership with p1
but points to an element inside the object.

