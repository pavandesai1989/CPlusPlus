class Buffer
{
    int* data;
    int size;

public:
    Buffer(int n)
    {
        size = n;
        data = new int[size];
    }

    // Deep Copy Constructor
    Buffer(const Buffer& other)
    {
        size = other.size;
        data = new int[size];

        for (int i = 0; i < size; i++)
            data[i] = other.data[i];

        cout << "Copy Constructor\n";
    }

    ~Buffer()
    {
        delete[] data;
    }
};

Usage:

Buffer b1(1000000);
Buffer b2 = b1;

What happens?

b1 ----> [1M integers]
b2 ----> [1M integers]

1. Allocate another array of 1M integers.
2. Copy all 1M elements.
3. Extra CPU work.
4. Extra memory usage.

Complexity:
O(n)

